<UserControl x:Class="Simulation.UI.Views.CrossingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Simulation.UI.ViewModels"
             Width="800" Height="600"
             Background="#E8F4F8"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    
    <Grid>
        
        <Rectangle Fill="#555" Width="100" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,50"/>

        
        <Canvas Width="100" Height="110" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Rectangle Canvas.Left="5"  Width="7" Height="100" Fill="White"/>
            <Rectangle Canvas.Left="20" Width="7" Height="100" Fill="White"/>
            <Rectangle Canvas.Left="35" Width="7" Height="100" Fill="White"/>
            <Rectangle Canvas.Left="50" Width="7" Height="100" Fill="White"/>
            <Rectangle Canvas.Left="65" Width="7" Height="100" Fill="White"/>
            <Rectangle Canvas.Left="80" Width="7" Height="100" Fill="White"/>
        </Canvas>

        
        <Rectangle Fill="#FFF" Width="100" Height="3" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   Margin="0,-200,0,0"
                   Opacity="0.6"/>

        
        <Border Background="White" CornerRadius="5" Padding="10" Margin="10"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                BorderBrush="Gray" BorderThickness="1">
            <TextBlock Text="{Binding LightState}" FontSize="18" FontWeight="Bold"
                       Foreground="{Binding LightState, Converter={StaticResource LightToColorConverter}}"/>
        </Border>

        
        <TextBlock Text="{Binding Entities.Count, StringFormat='Объектов: {0}'}"
                   FontSize="14" FontWeight="Bold" Margin="10,50,0,0"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Foreground="DarkBlue"/>

        
        <ItemsControl ItemsSource="{Binding Entities}" 
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="False"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:EntityViewModel}">
                    <Ellipse Width="24" Height="24" 
                             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}"
                             Stroke="Black" StrokeThickness="1">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <!-- 🚶 Обычный пешеход -->
                                    <DataTrigger Binding="{Binding Type}" Value="Pedestrian">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                    
                                    <!-- 🔥 Раненый пешеход (красный, чуть больше) -->
                                    <DataTrigger Binding="{Binding Type}" Value="Pedestrian_Injured">
                                        <Setter Property="Fill" Value="#E53935"/>
                                        <Setter Property="Width" Value="28"/>
                                        <Setter Property="Height" Value="28"/>
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </DataTrigger>
                                    
                                    <!-- 🚗 Обычная машина -->
                                    <DataTrigger Binding="{Binding Type}" Value="Car">
                                        <Setter Property="Fill" Value="#2196F3"/>
                                    </DataTrigger>
                                    
                                    <!-- 🚑 Аварийная служба (серая, крупнее) -->
                                    <DataTrigger Binding="{Binding Type}" Value="Car_Emergency">
                                        <Setter Property="Fill" Value="#666666"/>
                                        <Setter Property="Width" Value="28"/>
                                        <Setter Property="Height" Value="28"/>
                                    </DataTrigger>
                                    
                                    <!-- 🚛 Эвакуируемое авто (полупрозрачное) -->
                                    <DataTrigger Binding="{Binding Type}" Value="Car_Towed">
                                        <Setter Property="Fill" Value="#A0C4FF"/>
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>