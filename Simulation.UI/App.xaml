<Application x:Class="Simulation.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Simulation.UI.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:LightToColorConverter x:Key="LightToColorConverter"/>
        <converters:TypeToColorConverter x:Key="TypeToColorConverter"/>
    </Application.Resources>
</Application>